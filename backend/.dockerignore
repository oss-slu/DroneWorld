# Ignore Python virtual environments and cache files
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Ignore build/test artifacts
build/
dist/
*.egg-info/
.coverage
htmlcov/

# Ignore local logs and temporary files
*.log
tmp/
*.tmp

# Ignore OS-generated files
.DS_Store
Thumbs.db

# Ignore Git repository
.git/
.gitignore

# Secrets
.env
.env.*
